# Amped Up — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ── watsonx.ai (IBM Cloud) ────────────────────────────────────────────────────
# API key from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your-ibm-cloud-api-key-here

# Project ID from watsonx.ai project → Manage → General
WATSONX_PROJECT_ID=ca84b127-745f-4d8f-a8be-706a82a6f110

# Region URL — default is US South (Dallas)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
