# Amped Up - environment variables
# Copy to .env and fill in your values. Never commit .env.

# Supabase Postgres
# Use the URI from Supabase Project Settings > Database > Connection string.
# Prefer the transaction pooler for app runtime. Keep sslmode=require.
# The app accepts postgresql://, postgres://, or postgresql+psycopg://.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# watsonx.ai (IBM Cloud)
# API key from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your-ibm-cloud-api-key-here

# Project ID from watsonx.ai project > Manage > General
WATSONX_PROJECT_ID=ca84b127-745f-4d8f-a8be-706a82a6f110

# Region URL - default is US South (Dallas)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
